# NarrativeOS Environment Variables
# Copy to .env and fill in your keys

# --- Apify ---
NARRATIVEOS_APIFY_API_TOKEN=
NARRATIVEOS_APIFY_WEBHOOK_URL=

# --- Reddit API (optional — Playwright fallback works without these) ---
NARRATIVEOS_REDDIT_CLIENT_ID=
NARRATIVEOS_REDDIT_CLIENT_SECRET=
NARRATIVEOS_REDDIT_USER_AGENT=NarrativeOS/1.0

# --- Agents ---
NARRATIVEOS_EVENT_STREAM_URL=http://localhost:8000/api/v1/webhooks/apify-event

# --- Tracked Assets ---
NARRATIVEOS_TRACKED_TICKERS=NVDA,AMD,AAPL,MSFT,GOOGL,AMZN,META,TSLA,JPM,GS,SPY,QQQ,PLTR,AVGO,TSM,ARM
