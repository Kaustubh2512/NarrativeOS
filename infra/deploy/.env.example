# =============================================================================
# NarrativeOS — Superplane Deployment Configuration
# Copy to .env and fill in all values before running docker-compose up
# =============================================================================

# --- Database ---
NARRATIVEOS_DB_PASSWORD=changeme

# --- Superplane (Production Image: ghcr.io/superplanehq/superplane:v0.19.0) ---
NARRATIVEOS_SUPERPLANE_SECRET_KEY=generate-a-random-secret-key-here
NARRATIVEOS_ENCRYPTION_KEY=generate-a-random-encryption-key-here
NARRATIVEOS_SUPERPLANE_EXTERNAL_URL=http://localhost:3000
NARRATIVEOS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
NARRATIVEOS_LOG_LEVEL=info

# --- Apify (Member 1) ---
NARRATIVEOS_APIFY_API_TOKEN=your_apify_api_token_here
NARRATIVEOS_APIFY_WEBHOOK_URL=http://localhost:3000/api/v1/webhooks/apify-event

# --- Zynd Agent Endpoints (Member 2) ---
NARRATIVEOS_ZYND_ANALYZE_URL=http://zynd-agent-host/webhook/analyze
NARRATIVEOS_ZYND_NARRATIVE_URL=http://zynd-agent-host/webhook/narrative
NARRATIVEOS_ZYND_SENTIMENT_URL=http://zynd-agent-host/webhook/sentiment

# --- Zynd Agent Endpoints (Member 3 - Platform Lead) ---
NARRATIVEOS_ZYND_RISK_URL=http://risk-agent:8003/assess
NARRATIVEOS_ZYND_STRATEGY_URL=http://strategy-agent:8004/formulate
NARRATIVEOS_EXECUTION_API_URL=http://execution-api:8005/execute
NARRATIVEOS_MARKET_CORRELATION_URL=http://market-correlation-agent:8002/correlate

# --- Slack / Discord ---
NARRATIVEOS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
NARRATIVEOS_DISCORD_WEBHOOK_URL=

# --- PagerDuty ---
NARRATIVEOS_PAGERDUTY_INTEGRATION_KEY=your_pagerduty_integration_key_here

# --- GitHub ---
NARRATIVEOS_GITHUB_TOKEN=your_github_token_here
NARRATIVEOS_GITHUB_REPO=anomalyco/NarrativeOS

# --- OpenAI / LLM (for Superplane LLM nodes) ---
NARRATIVEOS_OPENAI_API_KEY=sk-your-openai-key-here
NARRATIVEOS_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- Agent 8: Visualization Agent ---
NARRATIVEOS_VIZ_AGENT_URL=http://visualization-agent:8001
NEXT_PUBLIC_SUPERPLANE_URL=http://superplane:3000
NARRATIVEOS_API_URL=http://visualization-agent:8001

# --- Execution API ---
NARRATIVEOS_EXECUTION_API_URL=http://execution-api:8005/execute

# --- Webhook Endpoints (defined in API_CONTRACT.md) ---
# Member 1 sends NarrativeEvents here:
WEBHOOK_APIFY_EVENT=/api/v1/webhooks/apify-event
# Member 3 forwards NarrativeEvents to Member 2 here:
ZYND_AGENT_ANALYZE_URL=
# Member 2 sends AnalysisSignals here:
WEBHOOK_SIGNAL=/api/v1/webhooks/signal
